<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - Book Notes</title>
    <link rel="stylesheet" href="/main.css" />
    <style>
      .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        text-align: center;
        padding: 20px;
      }
      .error-message {
        background: #2a1f1f;
        border: 1px solid #c74c3d;
        border-radius: 8px;
        padding: 30px;
        max-width: 500px;
        margin-bottom: 20px;
      }
      .error-message h1 {
        color: #f2b56c;
        margin: 0 0 10px 0;
        font-size: 24px;
      }
      .error-message p {
        color: #c74c3d;
        margin: 10px 0;
        font-size: 16px;
      }
      .error-message a {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 20px;
        background: #f2b56c;
        color: #0e1120;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        transition: background 0.3s;
      }
      .error-message a:hover {
        background: #d9a355;
      }
    </style>
  </head>
  <body>
    <%- include('partials/header.ejs') %>
    <div class="error-container">
      <div class="error-message">
        <h1>Oops!</h1>
        <p><%= message %></p>
        <a href="/">← Go Back Home</a>
      </div>
    </div>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
